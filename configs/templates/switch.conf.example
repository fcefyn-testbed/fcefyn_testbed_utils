# Switch Control - Configuration
#
# Option A: Manual use (script run by your user)
#   cp configs/templates/switch.conf.example ~/.config/switch.conf
#   chmod 600 ~/.config/switch.conf
#   Edit and add your switch password.
#
# Option B: PDUDaemon with Ansible (DynamicUser=yes)
#   PDUDaemon cannot read ~/.config/ (ProtectHome). Use a systemd override instead:
#   sudo mkdir -p /etc/systemd/system/pdudaemon.service.d
#   sudo tee /etc/systemd/system/pdudaemon.service.d/switch-password.conf << 'EOF'
#   [Service]
#   Environment=SWITCH_PASSWORD=your_password
#   Environment=SWITCH_HOST=<switch-ip>
#   Environment=SWITCH_USER=<switch-user>
#   EOF
#   sudo systemctl daemon-reload && sudo systemctl restart pdudaemon
#

SWITCH_PASSWORD=switch_password_here
SWITCH_HOST=<switch-ip>
SWITCH_USER=<switch-user>
SWITCH_DRIVER=tplink_jetstream
SWITCH_DEVICE_TYPE=tplink_jetstream
#POE_CYCLE_DELAY=3
