#
# Static SSH config for DUT access via labgrid-bound-connect.
# Each DUT alias connects through its isolated VLAN interface.
#
# For mesh VLAN 200 debugging (e.g. test crash left DUT on VLAN 200):
#   sudo labgrid-bound-connect vlan200 <mesh_ip> 22
# Mesh IPs: belkin-1=10.13.200.11, belkin-2=10.13.200.196,
#   belkin-3=10.13.200.118, bananapi=10.13.200.169,
#   openwrt-one=10.13.200.120, librerouter-1=10.13.200.77
#
# File: ~/.ssh/config
#
# IMPORTANT: Do NOT add HostName - each alias gets its own known_hosts entry.
# If you use HostName 192.168.1.1, all DUTs share one entry and you get
# "Host key verification failed" when switching VLANs.
#
# labgrid-fcefyn: for local testing. Labgrid connects as labgrid-dev to create
# TFTP symlinks. See host-config.md section 3.5 (fcefyn-lab key).
#

Host labgrid-fcefyn
   HostName labgrid-fcefyn
   User labgrid-dev
   IdentityFile ~/.ssh/id_ed25519_fcefyn_lab

Host oracle-vps
   HostName 159.112.143.145
   User ubuntu
   IdentityFile ~/.ssh/id_rsa_oci

Host switch-fcefyn
    HostName 192.168.0.1
    User admin
    PreferredAuthentications password
    PubkeyAuthentication no

Host gateway-openwrt
    HostName 192.168.100.254
    User root

# DUTs get reflashed frequently (different firmware = different host key).
# Disable host key checking for all dut-* aliases to avoid known_hosts errors.
Host dut-*
    StrictHostKeyChecking no
    UserKnownHostsFile /dev/null

Host dut-belkin-1
    User root
    ProxyCommand sudo labgrid-bound-connect vlan100 192.168.1.1 22

Host dut-belkin-2
    User root
    ProxyCommand sudo labgrid-bound-connect vlan101 192.168.1.1 22

Host dut-belkin-3
    User root
    ProxyCommand sudo labgrid-bound-connect vlan102 192.168.1.1 22

Host dut-bananapi
    User root
    ProxyCommand sudo labgrid-bound-connect vlan103 192.168.1.1 22

Host dut-openwrt-one
    User root
    ProxyCommand sudo labgrid-bound-connect vlan104 192.168.1.1 22

Host dut-librerouter-1
    User root
    ProxyCommand sudo labgrid-bound-connect vlan105 192.168.1.1 22

Host dut-librerouter-2
    User root
    ProxyCommand sudo labgrid-bound-connect vlan106 192.168.1.1 22

Host dut-librerouter-3
    User root
    ProxyCommand sudo labgrid-bound-connect vlan107 192.168.1.1 22
