[Unit]
Description=Arduino Relay Daemon - persistent serial connection to avoid auto-reset
After=network.target systemd-udev-settle.service

[Service]
Type=simple
ExecStart=/usr/bin/python3 /usr/local/bin/arduino_daemon.py start --port /dev/arduino-relay
Restart=on-failure
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
