#
# Requires: labgrid-dut-proxy installed and sudoers configured.
# labgrid-dut-proxy selects vlan200 (mesh) or per-device vlan (isolated)
# based on ~/.config/labgrid-vlan-mode (written by switch_vlan_preset.py).
# See host-config.md section 3.6 for details.
#
# File: ~/.ssh/config
#
# IMPORTANT: Do NOT add HostName - each alias gets its own known_hosts entry.
# If you use HostName 192.168.1.1, all DUTs share one entry and you get
# "Host key verification failed" when switching VLANs.
#
# labgrid-fcefyn: for local testing. Labgrid connects as labgrid-dev to create
# TFTP symlinks. See host-config.md section 3.5 (fcefyn-lab key).
#
Host labgrid-fcefyn
    HostName labgrid-fcefyn
    User labgrid-dev
    IdentityFile ~/.ssh/id_ed25519_fcefyn_lab

Host dut-belkin-1
    User root
    ProxyCommand sudo labgrid-dut-proxy belkin-1 192.168.1.1 22

Host dut-belkin-2
    User root
    ProxyCommand sudo labgrid-dut-proxy belkin-2 192.168.1.1 22

Host dut-belkin-3
    User root
    ProxyCommand sudo labgrid-dut-proxy belkin-3 192.168.1.1 22

Host dut-bananapi
    User root
    ProxyCommand sudo labgrid-dut-proxy bananapi 192.168.1.1 22

Host dut-openwrt-one
    User root
    ProxyCommand sudo labgrid-dut-proxy openwrt-one 192.168.1.1 22

Host dut-librerouter-1
    User root
    ProxyCommand sudo labgrid-dut-proxy librerouter-1 192.168.1.1 22

Host dut-librerouter-2
    User root
    ProxyCommand sudo labgrid-dut-proxy librerouter-2 192.168.1.1 22

Host dut-librerouter-3
    User root
    ProxyCommand sudo labgrid-dut-proxy librerouter-3 192.168.1.1 22

Host dut-glinet-mango
    User root
    ProxyCommand sudo labgrid-dut-proxy glinet-mango 192.168.1.1 22

Host switch-fcefyn
    HostName 192.168.0.1
    User admin
    PreferredAuthentications password
    PubkeyAuthentication no
