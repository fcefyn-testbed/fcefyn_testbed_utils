# Prometheus scrape job — orchestration host (prometheus-node-exporter)
# Generated by Ansible (observability role). Do not edit manually.
# Metrics endpoint: {{ orchestrator_node_exporter.listen_address }}:{{ orchestrator_node_exporter.listen_port }}

scrape_configs:
  - job_name: '{{ orchestrator_node_exporter.scrape_job_name }}'
    scrape_interval: 30s
    scrape_timeout: 10s
    static_configs:
      - targets: ['{{ orchestrator_node_exporter.listen_address }}:{{ orchestrator_node_exporter.listen_port }}']
        labels:
{% for key, value in orchestrator_node_exporter.labels.items() %}
          {{ key }}: '{{ value }}'
{% endfor %}
