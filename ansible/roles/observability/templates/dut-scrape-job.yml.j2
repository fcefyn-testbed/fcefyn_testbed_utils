# Prometheus scrape job — {{ item.name }}
# Generated by Ansible (observability role). Do not edit manually.
# Metrics endpoint: 127.0.0.1:{{ item.local_port }} via dut-metrics-tunnel-{{ item.name }}.service

scrape_configs:
  - job_name: '{{ item.name }}'
    scrape_interval: 30s
    scrape_timeout: 10s
    static_configs:
      - targets: ['127.0.0.1:{{ item.local_port }}']
        labels:
{% for key, value in item.labels.items() %}
          {{ key }}: '{{ value }}'
{% endfor %}
