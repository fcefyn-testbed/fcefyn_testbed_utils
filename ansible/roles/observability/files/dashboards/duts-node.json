      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineInterpolation": "smooth", "lineWidth": 1, "showPoints": "never", "spanNulls": true },
          "unit": "celsius"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 51 },
