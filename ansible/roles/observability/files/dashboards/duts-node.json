      "id": 65,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "Wi-Fi radio temps (ieee80211 phy)",
