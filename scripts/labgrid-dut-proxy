#!/usr/bin/env python3
"""
labgrid-dut-proxy - SSH ProxyCommand for DUT access with dynamic VLAN detection.

Queries the switch for the current PVID of the DUT's port to determine
whether to connect via isolated VLAN (192.168.1.1) or mesh VLAN (10.13.x.x).

Config: /etc/labgrid/dut-proxy.yaml (deployed by Ansible per lab).
Requires: labgrid-switch-abstraction package, labgrid-bound-connect.

Usage: labgrid-dut-proxy <device-id> <host> <port>
  e.g. labgrid-dut-proxy belkin-1 192.168.1.1 22

Sudoers: ALL ALL = NOPASSWD: /usr/local/sbin/labgrid-dut-proxy
"""

import os
import sys

LABGRID_BOUND_CONNECT = "/usr/local/sbin/labgrid-bound-connect"
CONFIG_PATH = "/etc/labgrid/dut-proxy.yaml"


def load_config(path: str) -> dict:
    with open(path, encoding="utf-8") as f:
        content = f.read()
    try:
        import yaml
        return yaml.safe_load(content) or {}
    except ImportError:
        raise RuntimeError("PyYAML required: pip install pyyaml") from None


def get_pvid_for_device(device_id: str, device_cfg: dict) -> int | None:
    """Query switch for the current PVID of this device's port.

    Uses dut-config.yaml (via SWITCH_DUT_CONFIG) to map the SSH alias
    to a physical switch port, then queries the switch.
    """
    try:
        from switch_abstraction.client import SwitchClient
        from switch_abstraction.vlan_manager import load_dut_map
    except ImportError:
        return None

    dut_map = load_dut_map()
    dut_name = None
    for name, hw in dut_map.items():
        alias = hw.get("ssh_alias", "")
        proxy_id = alias.replace("dut-", "") if alias.startswith("dut-") else alias
        if proxy_id == device_id:
            dut_name = name
            break

    if dut_name is None:
        return None

    port = dut_map[dut_name].get("switch_port")
    if port is None:
        return None

    try:
        client = SwitchClient()
        return client.get_port_pvid(port)
    except Exception as e:
        print(f"labgrid-dut-proxy: switch query failed: {e}", file=sys.stderr)
        return None


def resolve_mode(pvid: int | None, device_cfg: dict) -> dict | None:
    """Match PVID to isolated or mesh config entry."""
    if pvid is None:
        return device_cfg.get("isolated")

    iso = device_cfg.get("isolated", {})
    mesh = device_cfg.get("mesh", {})

    if iso.get("vlan") == pvid:
        return iso
    if mesh.get("vlan") == pvid:
        return mesh

    return iso


def main() -> int:
    if len(sys.argv) != 4:
        print("Usage: labgrid-dut-proxy <device-id> <host> <port>", file=sys.stderr)
        return 1

    device_id = sys.argv[1]
    port_str = sys.argv[3]

    env_path = os.environ.get("LABGRID_DUT_PROXY_CONFIG")
    config_path = env_path if env_path and os.path.isfile(env_path) else CONFIG_PATH
    if not os.path.isfile(config_path):
        print(f"labgrid-dut-proxy: config not found at {config_path}", file=sys.stderr)
        return 1

    try:
        config = load_config(config_path)
    except Exception as e:
        print(f"labgrid-dut-proxy: failed to load config: {e}", file=sys.stderr)
        return 1

    devices = config.get("devices") or {}
    if device_id not in devices:
        print(f"labgrid-dut-proxy: unknown device '{device_id}'", file=sys.stderr)
        print(f"Known devices: {', '.join(sorted(devices))}", file=sys.stderr)
        return 1

    device_cfg = devices[device_id]
    pvid = get_pvid_for_device(device_id, device_cfg)
    mode_cfg = resolve_mode(pvid, device_cfg)

    if not mode_cfg or "vlan" not in mode_cfg:
        print(f"labgrid-dut-proxy: cannot resolve VLAN for '{device_id}'", file=sys.stderr)
        return 1

    vlan = mode_cfg["vlan"]
    host = mode_cfg.get("ip", "192.168.1.1")
    ifname = f"vlan{vlan}"

    os.execv(
        LABGRID_BOUND_CONNECT,
        [LABGRID_BOUND_CONNECT, ifname, host, port_str],
    )
    return 0


if __name__ == "__main__":
    sys.exit(main())
